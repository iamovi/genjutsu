# ============================================================
# GENJUTSU — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values for local development.
# In production (Vercel), secrets are served via a Cloudflare Worker —
# you only need VITE_CONFIG_WORKER_URL in Vercel environment variables.
# ============================================================


# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"


# ── AI (Groq) ─────────────────────────────────────────────────
# Get your key from: https://console.groq.com
VITE_GROQ_API_KEY="your_groq_api_key_here"


# ── Realtime Stranger Chat (Ably) ─────────────────────────────
# Get your key from: https://ably.com
VITE_ABLY_KEY=""


# ── Translation Service ───────────────────────────────────────
# Your deployed Lingua Bridge server URL
VITE_LANG_SERVICE=""


# ── Admin Emails ──────────────────────────────────────────────
# Comma-separated list of admin emails.
# Note: Adding an email here only shows the admin button in the UI.
# Actual admin access requires being added to the admin list in Supabase by Ovi ren.
VITE_ADMIN_EMAILS="email1@example.com,email2@example.com"


# ── Sentry Error Tracking ─────────────────────────────────────
# Get your DSN from: https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=""


# ── Push Notifications (VAPID) ──────────────────────────────
# Public VAPID key for Web Push API subscriptions.
# The private key must be set in Supabase Edge Function env vars (never expose it here).
VITE_VAPID_PUBLIC_KEY="BHr3-0PCvg8CO5gsel4wr6DxXEn1QoS3x0OhNiTjAQq-gihRo69ZjQQqTQJkKKqmkQdLJM_j4ypTN4DiK7QJySw"


# ── Cloudflare Worker (Production only) ───────────────────────
# In production, all secrets above are served by a Cloudflare Worker.
# Set this in Vercel environment variables — NOT needed locally.
# Format: https://your-worker-name.your-subdomain.workers.dev/config
# VITE_CONFIG_WORKER_URL="https://genjutsu-config.yourname.workers.dev/config"


# ── Google OAuth ──────────────────────────────────────────────
# Google OAuth is configured directly in the Supabase Dashboard under
# Authentication → Providers. You do NOT need to add anything here.
# The client handles it automatically via supabase.auth.signInWithOAuth().
